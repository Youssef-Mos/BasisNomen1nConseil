// =============================================================================
// Basis Norm Explorer — Database Schema (Jalon 1 Refactor)
// PostgreSQL + Prisma
//
// Architecture:
//   Document → Rectangle (self-referencing tree via fatherId)
//
// ALL structure is created manually by Admin.
// No automatic detection. Rectangle is the CORE entity.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// RectangleType
//
// Enum for the type of content a rectangle represents.
// -----------------------------------------------------------------------------
enum RectangleType {
  phrase
  paragraph
  article
  section
  figure
  table
  formula
  annexe
}

// -----------------------------------------------------------------------------
// Document
//
// One row = one uploaded PDF.
// fileHash (SHA-256) prevents duplicate uploads.
// pdfPath is the storage path to the original PDF file.
// pageCount is extracted on upload.
// -----------------------------------------------------------------------------
model Document {
  id        String   @id @default(cuid())
  title     String
  pdfPath   String
  fileHash  String   @unique
  pageCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rectangles Rectangle[]

  @@index([createdAt])
  @@map("documents")
}

// -----------------------------------------------------------------------------
// Rectangle
//
// CORE ENTITY of the system.
// One row = one manually-drawn rectangle on a PDF page.
//
// Hierarchy: self-referencing tree via fatherId.
// Labels: string array, inherited recursively from parent.
// Text: multi-language (EN / FR / NL).
// Coordinates: percentages (0–100) relative to page dimensions.
//   x=0 left edge, x=100 right edge, y=0 top, y=100 bottom.
//
// Rectangles MUST NOT overlap on the same page.
// -----------------------------------------------------------------------------
model Rectangle {
  id         String        @id @default(cuid())
  documentId String
  fatherId   String?
  type       RectangleType @default(paragraph)
  labels     String[]
  textFr     String?
  textEn     String?
  textNl     String?
  page       Int
  x          Float
  y          Float
  width      Float
  height     Float
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  document Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  father   Rectangle?  @relation("RectangleTree", fields: [fatherId], references: [id], onDelete: SetNull)
  children Rectangle[] @relation("RectangleTree")

  @@index([documentId])
  @@index([documentId, page])
  @@index([fatherId])
  @@map("rectangles")
}

// -----------------------------------------------------------------------------
// AdminOtp
//
// One-time password for admin login. One active record at a time.
// Older records are marked used=true before creating a new one.
// -----------------------------------------------------------------------------
model AdminOtp {
  id        String   @id @default(cuid())
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("admin_otps")
}
