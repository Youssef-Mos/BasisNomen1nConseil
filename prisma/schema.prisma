// =============================================================================
// Basis Norm Explorer — Database Schema (Jalon 2 Refactor)
// PostgreSQL + Prisma
//
// Architecture:
//   Norm → Document → Rectangle (self-referencing tree via fatherId)
//
// ALL structure is created manually by Admin.
// No automatic detection. Rectangle is the CORE entity.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// RectangleType
//
// Enum for the type of content a rectangle represents.
// Jalon 2: added hierarchical subsection levels and orderOnPage on Rectangle.
// NEVER remove or rename existing values — PostgreSQL rejects migrations that
// drop enum values used by existing rows.
// -----------------------------------------------------------------------------
enum RectangleType {
  phrase
  paragraph
  article
  section
  subsection
  subSubsection
  subSubSubsection
  subSubSubSubsection
  subSubSubSubSubsection
  subSubSubSubSubSubsection
  figure
  table
  formula
  annexe
}

// -----------------------------------------------------------------------------
// Norm
//
// A normative reference (e.g. "NBN S21-201").
// Multiple Document versions can belong to the same Norm.
// -----------------------------------------------------------------------------
model Norm {
  id          String     @id @default(cuid())
  name        String
  description String?
  country     String     @default("BE")
  createdAt   DateTime   @default(now())
  documents   Document[]

  @@map("norms")
}

// -----------------------------------------------------------------------------
// Document
//
// One row = one uploaded PDF.
// fileHash (SHA-256) prevents duplicate uploads.
// pdfPath is the storage path to the original PDF file.
// pageCount is extracted on upload.
// normId is nullable: a PDF can exist without an assigned norm.
// -----------------------------------------------------------------------------
model Document {
  id        String   @id @default(cuid())
  title     String
  pdfPath   String
  fileHash  String   @unique
  pageCount Int      @default(0)
  normId    String?
  version   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  norm       Norm?       @relation(fields: [normId], references: [id])
  rectangles Rectangle[]

  @@index([createdAt])
  @@index([normId])
  @@map("documents")
}

// -----------------------------------------------------------------------------
// Rectangle
//
// CORE ENTITY of the system.
// One row = one manually-drawn rectangle on a PDF page.
//
// Hierarchy: self-referencing tree via fatherId.
// Labels: string array, inherited recursively from parent.
// Text: multi-language (EN / FR / NL).
// Coordinates: percentages (0–100) relative to page dimensions.
//   x=0 left edge, x=100 right edge, y=0 top, y=100 bottom.
// orderOnPage: reading order on the page (nullable, calculated externally).
//
// Rectangles MUST NOT overlap on the same page.
// -----------------------------------------------------------------------------
model Rectangle {
  id          String        @id @default(cuid())
  documentId  String
  fatherId    String?
  type        RectangleType @default(paragraph)
  labels      String[]
  textFr      String?
  textEn      String?
  textNl      String?
  page        Int
  x           Float
  y           Float
  width       Float
  height      Float
  orderOnPage Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  document Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  father   Rectangle?  @relation("RectangleTree", fields: [fatherId], references: [id], onDelete: SetNull)
  children Rectangle[] @relation("RectangleTree")

  @@index([documentId])
  @@index([documentId, page])
  @@index([fatherId])
  @@map("rectangles")
}

// -----------------------------------------------------------------------------
// AdminOtp
//
// One-time password for admin login. One active record at a time.
// Older records are marked used=true before creating a new one.
// -----------------------------------------------------------------------------
model AdminOtp {
  id        String   @id @default(cuid())
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("admin_otps")
}
